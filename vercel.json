{
  "framework": "nextjs",
  "buildCommand": "npm run prisma:generate && next build",
  "installCommand": "npm install --legacy-peer-deps",
  "functions": {
    "app/api/**": {
      "maxDuration": 30
    }
  },
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" }
      ]
    }
  ]
}
